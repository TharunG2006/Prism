# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB Configuration (Free Tier: MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/prism

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key

# Cloudinary Configuration (Free Tier: Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (Free Tier: Brevo/Resend/Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Prism <noreply@prism.com>

# Security
NODE_ENV=development
